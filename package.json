{
  "name": "teaching-portal-system",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.5"
  },
  "overrides": {
    "jsdom": "26.1.0"
  },
  "scripts": {
    "predev": "node scripts/dev-prep.js",
    "prebuild": "node scripts/prebuild-clean-next-dev.js",
    "dev": "cross-env NODE_OPTIONS=--use-system-ca next dev --port 3000 --turbopack",
    "dev:webpack": "cross-env NODE_OPTIONS=--use-system-ca next dev --port 3000 --webpack",
    "dev:turbo": "cross-env NODE_OPTIONS=--use-system-ca next dev --port 3000 --turbopack",
    "build": "cross-env NODE_OPTIONS=\"--use-system-ca --require=./scripts/suppress-baseline-warning.cjs\" BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true BROWSERSLIST_IGNORE_OLD_DATA=true next build",
    "start": "cross-env NODE_OPTIONS=--use-system-ca next start",
    "lint": "eslint",
    "db:migrate": "node scripts/run-all-migrations.js",
    "ngrok:auth": "ngrok config add-authtoken",
    "ngrok": "ngrok http 3000 --pooling-enabled"
  },
